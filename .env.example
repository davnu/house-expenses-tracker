VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Self-hosted Umami analytics (cookieless, no consent banner required).
# Marketing surface only (landing, /login, /privacy, /invite). Never fires inside /app/*.
# Deploy Umami to Vercel + Neon Postgres — see docs at https://umami.is/docs.
# Leave both empty to disable analytics entirely.
VITE_UMAMI_HOST=
VITE_UMAMI_WEBSITE_ID=

# Google Search Console site verification (meta tag content value).
# Free, no user tracking, no cookies. Leave empty to skip.
VITE_GSC_VERIFICATION=

# ─────────────────────────────────────────────────────────────────────────────
# Gemini 3 Pro Image ("Nano Banana Pro") — blog hero image generation
#
# Used ONLY by build-time Node scripts (scripts/generate-hero-image.mjs).
# NEVER by the client bundle — no VITE_ prefix means Vite will not expose
# this to the browser. The key stays server-side.
#
# Get a key:  https://aistudio.google.com/apikey
# Pricing:    ~$0.035/image at 2K 16:9 (as of 2025-12). For a blog publishing
#             weekly, expect <$1/month.
# Watermark:  API-generated images carry ONLY the invisible SynthID
#             provenance signal — no visible corner mark, unlike the
#             consumer app at gemini.google.com.
#
# When set, running /new-article auto-generates the hero image via the API.
# When empty, /new-article prints the prompts and you generate manually.
GEMINI_API_KEY=

# Override the image model if Google renames the endpoint or ships a newer
# version. Defaults to "gemini-3-pro-image-preview" when empty.
GEMINI_IMAGE_MODEL=
# ─────────────────────────────────────────────────────────────────────────────

# Firebase App Check — reCAPTCHA v3 site key for the production domain.
# When set, the client attests to callable functions (createCheckoutSession)
# so script-based abuse of the checkout endpoint is blocked.
# Get a site key at Firebase console → App Check → Register app.
# Leave empty in dev to disable (server-side enforceAppCheck is still configured
# — you'll need to also register a debug token in the Firebase console for local dev).
VITE_APPCHECK_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Polar.sh billing (server-side only — configured as Firebase Functions secrets,
# NOT as client-visible VITE_* vars). Set via:
#   firebase functions:secrets:set POLAR_API_KEY
#   firebase functions:secrets:set POLAR_WEBHOOK_SECRET
#   firebase functions:secrets:set POLAR_PRODUCT_ID_PRO
#   firebase functions:secrets:set POLAR_PRODUCT_ID_ADDITIONAL_HOUSE
#
# Products to create in the Polar dashboard:
#   - Pro (first house)    — €49 one-time
#   - Additional house     — €29 one-time
#
# Webhook URL to register in Polar (preferred: brand-domain rewrite via
# Firebase Hosting — see firebase.json rewrites):
#   https://casatab.com/api/polar-webhook
# (Direct Cloud Function URL also works as a fallback:
#   https://europe-west1-<project-id>.cloudfunctions.net/onPolarWebhook)
#
# Webhook events to subscribe to (in the Polar dashboard):
#   Required:
#     - order.paid        → grants Pro when the customer pays
#     - order.refunded    → revokes Pro on refund (also covers chargebacks in Polar)
#   Optional (safe, the webhook just acks 200):
#     - order.created, order.updated
#     - checkout.created, checkout.updated, checkout.expired (for future analytics)
#
# ─── Cloud Function runtime env vars (NOT secrets — set via gcloud or
#     firebase functions:config set / the Firebase console env editor):
#
# POLAR_API_BASE       — Polar API base URL. Defaults to production
#                        (https://api.polar.sh/v1). Set to
#                        https://sandbox-api.polar.sh/v1 to test against
#                        Polar's sandbox environment.
#
# CASATAB_ORIGIN       — Public web origin used in Polar success URLs.
#                        Defaults to https://casatab.com. Override only if you
#                        are deploying to a different branded domain.
#
# ENFORCE_APP_CHECK    — Set to "true" to require an App Check token on every
#                        callable invocation (createCheckoutSession,
#                        reconcileOrder). Only turn this on AFTER App Check is
#                        fully wired up client-side (reCAPTCHA v3 site key in
#                        VITE_APPCHECK_SITE_KEY + registered in the Firebase
#                        console). Enabling it before the client is ready will
#                        401 every legitimate request.
#
# WEBHOOK_DEBUG        — Set to "true" to log every webhook delivery's
#                        signature + body preview for one-off diagnostics.
#                        Verbose; keep off in production under normal
#                        operation.
# ─────────────────────────────────────────────────────────────────────────────
