rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Email verification: require verified email for writes (except user profiles).
    function isVerifiedEmail() {
      return request.auth.token.email_verified == true;
    }

    // User profiles — each user can read any profile, write only their own
    // Exception: house owner can clear a member's houseId when removing them
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.resource.data.houseId == null
                    && resource.data.houseId != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['houseId'])
                    && get(/databases/$(database)/documents/houses/$(resource.data.houseId)).data.ownerId == request.auth.uid;
    }

    // Houses
    match /houses/{houseId} {
      function isMember() {
        return exists(/databases/$(database)/documents/houses/$(houseId)/members/$(request.auth.uid));
      }

      function isOwner() {
        return get(/databases/$(database)/documents/houses/$(houseId)).data.ownerId == request.auth.uid;
      }

      // Defence-in-depth shape check for the household cost-sharing ratio.
      // Full sum / per-uid validation is enforced client-side; rules just reject
      // garbage types and size mismatches a buggy client could otherwise write.
      function costSplitShapeOk() {
        return !('costSplit' in request.resource.data)
               || request.resource.data.costSplit == null
               || (request.resource.data.costSplit is list
                   && request.resource.data.costSplit.size() == request.resource.data.memberIds.size());
      }

      allow create: if request.auth != null && isVerifiedEmail()
                    && request.resource.data.ownerId == request.auth.uid
                    && costSplitShapeOk();
      // Any authenticated user can read house doc (needed for invite join flow)
      // House IDs are not guessable and data is not sensitive (just name + memberIds)
      allow read: if request.auth != null;
      allow update: if request.auth != null && isVerifiedEmail()
                    && (isMember()
                        // Allow joining user to add themselves to memberIds (transaction race)
                        || (request.auth.uid in request.resource.data.memberIds
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])))
                    // Only the owner can set deletedAt (soft-delete)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['deletedAt'])
                        || resource.data.ownerId == request.auth.uid)
                    // Cost split shape check only applies when the field is being touched
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['costSplit'])
                        || costSplitShapeOk());
      allow delete: if request.auth != null && isVerifiedEmail()
                    && request.auth.uid == resource.data.ownerId;

      // Members
      match /members/{memberId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && isVerifiedEmail()
                      && (isMember() || request.auth.uid == memberId);
        allow update: if request.auth != null && isVerifiedEmail()
                      && request.auth.uid == memberId;
        allow delete: if request.auth != null && isVerifiedEmail()
                      && (request.auth.uid == memberId || isOwner());
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember();
      }

      // Recurring
      match /recurring/{recurringId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember();
      }

      // Settings (mortgage config, house settings, etc.)
      //
      // ALLOWLIST not denylist — any future admin-only meta doc is denied by
      // default. To let the client write a new meta doc, add its docId here
      // explicitly. Admin-SDK Cloud Functions bypass these rules regardless.
      //
      // Client-writable docs:
      //   - settings     → currency/country overrides
      //   - mortgage     → mortgage config (principal, rate, term, rate periods, etc.)
      //   - budget       → spending budget configuration
      //
      // Admin-only docs (NOT in allowlist, written by Cloud Functions only):
      //   - storage      → used-byte quota (enforced by storage-quota function)
      //   - entitlement  → billing tier (written by Polar webhook)
      match /meta/{docId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember()
                    && (docId == 'settings' || docId == 'mortgage' || docId == 'budget');
      }

      // Document folders
      match /folders/{folderId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember();
      }

      // Documents (files stored in folders)
      match /documents/{documentId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember();
      }

      // Todos
      match /todos/{todoId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isVerifiedEmail() && isMember();
      }

      // Notifications — written only by Cloud Functions (admin SDK), readable
      // by house members so the UI can surface them. Members can delete
      // (i.e. dismiss) but never create/update.
      match /notifications/{notificationId} {
        allow read: if request.auth != null && isMember();
        allow delete: if request.auth != null && isVerifiedEmail() && isMember();
        allow create, update: if false;
      }
    }

    // Reference rates — public data, written by Cloud Functions only
    match /reference_rates/{rateId} {
      allow read: if true;
      allow write: if false; // only Cloud Functions (admin SDK) can write
    }

    // Webhook audit log — server-only, not user-facing. Deny all client
    // access; inspect via Firebase console.
    match /webhook_attempts/{attemptId} {
      allow read: if false;
      allow write: if false;
    }

    // Polar order idempotency markers — server-only. Written inside the
    // additional_house provisioning transaction so webhook retries and
    // reconcile calls converge on the same houseId. Must never be
    // client-readable/writable: Polar order ids are the rate-limit-free
    // "which house did this order provision?" lookup and would leak other
    // users' purchase history otherwise.
    match /polar_orders/{polarOrderId} {
      allow read: if false;
      allow write: if false;
    }

    // Invites — readable by anyone (unauthenticated users need to see house name on landing page)
    // Creates restricted to authenticated users
    // Updates restricted: only usedBy/usedAt fields can be changed (marking invite as used)
    match /invites/{inviteId} {
      allow read: if true;
      allow create: if request.auth != null && isVerifiedEmail();
      allow update: if request.auth != null && isVerifiedEmail()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['usedBy', 'usedAt']);
    }
  }
}
