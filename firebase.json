{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "trailingSlash": true,
    "predeploy": ["npm --prefix \"$PROJECT_DIR\" run build"],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" },
          { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
        ]
      },
      {
        "source": "**/feed.xml",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=1800, s-maxage=3600" },
          { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }
        ]
      },
      {
        "source": "**/feed.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=1800, s-maxage=3600" },
          { "key": "Content-Type", "value": "application/feed+json; charset=utf-8" }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/en",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/en/",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/en/blog",
        "destination": "/blog",
        "type": 301
      },
      {
        "source": "/en/blog/**",
        "destination": "/blog/:1",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/polar-webhook",
        "function": {
          "functionId": "onPolarWebhook",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "emulators": {
    "firestore": {
      "port": 5180
    },
    "auth": {
      "port": 5199
    },
    "storage": {
      "port": 5299
    },
    "hub": {
      "port": 5400
    }
  }
}
