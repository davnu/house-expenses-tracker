rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Shared helper: require verified email for writes
    function isVerifiedEmail() {
      return request.auth.token.email_verified == true;
    }

    // Shared helper: check household membership
    function isHouseMember(houseId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/houses/$(houseId)/members/$(request.auth.uid));
    }

    // Shared helper: validate file upload constraints
    function isValidUpload(houseId) {
      return isVerifiedEmail()
        && isHouseMember(houseId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
          'image/(png|jpeg|webp|gif|heic|heif)|application/pdf|application/msword|application/vnd\\.openxmlformats-officedocument\\.(wordprocessingml\\.document|spreadsheetml\\.sheet)|application/vnd\\.ms-excel'
        );
    }

    // Expense attachments
    match /houses/{houseId}/attachments/{allPaths=**} {
      allow read: if isHouseMember(houseId);
      allow create, update: if isValidUpload(houseId);
      allow delete: if isVerifiedEmail() && isHouseMember(houseId);
    }

    // Standalone documents (documents feature)
    match /houses/{houseId}/documents/{allPaths=**} {
      allow read: if isHouseMember(houseId);
      allow create, update: if isValidUpload(houseId);
      allow delete: if isVerifiedEmail() && isHouseMember(houseId);
    }
  }
}
