rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Household attachments — any authenticated user can access
    // (Firestore membership check via storage rules requires Blaze plan,
    //  so we use simple auth check here — sufficient for a personal project)
    match /houses/{houseId}/attachments/{allPaths=**} {
      allow read, write: if request.auth != null;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
  }
}
